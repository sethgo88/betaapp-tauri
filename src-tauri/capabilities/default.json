{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:path:default",
		"opener:default",
		"core:window:default",
		"sql:default",
		"sql:allow-load",
		"sql:allow-execute",
		"sql:allow-close",
		"sql:allow-select",
		"deep-link:default",
		"deep-link:allow-get-current",
		"deep-link:allow-is-registered",
		"deep-link:allow-register",
		"deep-link:allow-unregister"
	]
}
